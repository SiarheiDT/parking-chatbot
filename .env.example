ENV=dev
DB_PATH=data/db/parking_dev.db
VECTOR_DB_PATH=data/processed/vector_store
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
TOP_K=3
LOG_LEVEL=debug
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8081
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION_NAME=ParkingDoc
CHUNK_SIZE=700
CHUNK_OVERLAP=100
# First free slot search when lot is full (concurrent reservations vs parking_availability)
PARKING_SLOT_STEP_MINUTES=30
PARKING_SLOT_SEARCH_MAX_DAYS=14
# Guardrails: SentenceTransformer semantic similarity vs sensitive-intent phrases (uses EMBEDDING_MODEL_NAME)
GUARDRAILS_SEMANTIC_ENABLED=true
GUARDRAILS_SEMANTIC_THRESHOLD=0.52
# Optional HF token to avoid hub warning/rate limits
HF_TOKEN=
# Optional runtime noise controls
TRANSFORMERS_VERBOSITY=error
HF_HUB_DISABLE_PROGRESS_BARS=1
TOKENIZERS_PARALLELISM=false